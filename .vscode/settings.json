{
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "files.trimTrailingWhitespace": false
  },
  "[html]": {
    "editor.formatOnSave": false,
    "editor.wordWrap": "on"
  },
  "editor.rulers": [100],
  "files.autoSave": "onFocusChange",
  "markdownlint.config": {
    "MD013": false,
    "MD033": false,
    "MD041": false,
    "MD024": { "siblings_only": true }
  },
  "todo-tree.general.tags": [
    "TODO",
    "FIXME",
    "REVIEW",
    "DECISION",
    "POLICY",
    "BLOCKED"
  ],
  "cSpell.words": [
    "TeamAM",
    "Jotform",
    "Cronometer",
    "Ekkolyte",
    "biweekly",
    "recomp",
    "macros",
    "psyllium"
  ]
}
